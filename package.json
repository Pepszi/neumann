{
	"name": "neumann",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build:articles": "node scripts/build-articles.mjs",
		"build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
		"build:vendor": "mkdir -p js/vendor && cp node_modules/gsap/dist/gsap.min.js js/vendor/gsap.min.js",
		"build": "npm run build:vendor && npm run build:articles && npm run build:css",
		"dev:articles": "node scripts/build-articles.mjs",
		"dev": "npm run dev:articles && tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.3.1",
		"@tailwindcss/typography": "^0.5.16",
		"gray-matter": "^4.0.3",
		"marked": "^15.0.12",
		"tailwindcss": "^4.3.1"
	},
	"dependencies": {
		"gsap": "^3.12.7"
	}
}
